### 1. Login to get the JWT token
# @name login
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "email": "test-player@nightcity.com",
  "password": "supersecurepassword"
}

### Store the token from the login response
@token = {{login.response.body.token}}

### 2. Get Avatar ID from the Protected Dashboard
# @name dashboard
GET http://localhost:3000/api/avatars/me/dashboard
Authorization: Bearer {{token}}

### Store the avatarId from the dashboard response
@avatarId = {{dashboard.response.body.id}}

### 3. Create a new Skill
# @name createSkill
POST http://localhost:3000/api/skills
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "avatarId": "{{avatarId}}",
  "name": "Backend Development",
  "category": "INTELLECTUAL"
}

### Store the skillId from the newly created skill response
@skillId = {{createSkill.response.body.id}}

### 4. Create a Quest linked to the new Skill
# @name createTask
POST http://localhost:3000/api/tasks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "skillId": "{{skillId}}",
  "title": "Build manual skills controller",
  "description": "Create CRUD endpoints before wiring up Gemini",
  "expReward": 150
}

### Store the taskId from the created task response
@taskId = {{createTask.response.body.id}}

### 5. Complete the Quest & Earn XP!
PATCH http://localhost:3000/api/tasks/{{taskId}}/complete
Authorization: Bearer {{token}}